# OpenVan environment overrides — copy to `.env` and fill in.
#
#   cp .env.example .env      # then edit .env (it's gitignored) and restart Core
#
# Loaded by Core on startup (config.py). The main use is the online API key, which
# is otherwise memory-only and lost on restart. `.env` is gitignored so secrets
# never land in git. NOTE: anything you set here OVERRIDES the Admin UI on every
# restart — so leave provider/model/connectivity commented and pick them in the UI
# unless you deliberately want env to be the source of truth.

# --- Online (cloud) model API key (the thing worth persisting) ---
OPENVAN_ONLINE_API_KEY=

# --- Optional overrides (uncomment only if you want env to win over the UI) ---
# OPENVAN_ONLINE_PROVIDER=openai          # openai | openai_compatible | anthropic
# OPENVAN_ONLINE_URL=https://your/v1      # openai_compatible endpoint only
# OPENVAN_ONLINE_MODEL=gpt-4o-mini
# OPENVAN_CONNECTIVITY=online             # offline | online
# OPENVAN_LANGUAGE=en                     # en | sv | de
# OPENVAN_LLM_URL=http://127.0.0.1:11434  # local Ollama
# OPENVAN_LLM_MODEL=llama3.2
